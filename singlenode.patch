+
+fn detect_socket(driver: RuntimeDriver) -> Option<PathBuf> {
+    if let Ok(docker_host) = env::var("DOCKER_HOST") {
+        if let Some(path) = docker_host.strip_prefix("unix://") {
+            return Some(PathBuf::from(path));
+        }
+    }
+    match driver {
+        RuntimeDriver::Docker => Some(PathBuf::from("/var/run/docker.sock")),
+        RuntimeDriver::Podman => {
+            let mut candidates = Vec::new();
+            if let Ok(xdg) = env::var("XDG_RUNTIME_DIR") {
+                candidates.push(PathBuf::from(xdg).join("podman/podman.sock"));
+            }
+            candidates.push(PathBuf::from("/run/podman/podman.sock"));
+            candidates.push(PathBuf::from("/var/run/docker.sock"));
+            candidates.into_iter().find(|path| path.exists())
+        }
+    }
+}
+
+fn command_exists(program: &str) -> bool {
+    if program.contains(std::path::MAIN_SEPARATOR) {
+        return Path::new(program).exists();
+    }
+    env::var_os("PATH")
+        .map(|paths| {
+            env::split_paths(&paths).any(|dir| {
+                let candidate = dir.join(program);
+                candidate.exists() && candidate.is_file()
+            })
+        })
+        .unwrap_or(false)
+}
+
+fn normalize(value: &str) -> String {
+    value.trim().to_ascii_lowercase().replace('_', "-")
+}
+
+fn sanitize_env_value(value: &str) -> String {
+    value.replace(['\n', '\r'], " ")
+}
+
+fn now_unix() -> u64 {
+    SystemTime::now()
+        .duration_since(UNIX_EPOCH)
+        .map(|duration| duration.as_secs())
+        .unwrap_or(0)
+}
+
+fn remove_file_if_exists(path: &Path) -> Result<()> {
+    if path.exists() {
+        fs::remove_file(path)?;
+    }
+    Ok(())
+}
+
+fn read_tail(path: &Path, max_lines: usize) -> Result<String> {
+    if !path.exists() {
+        return Ok("<not collected yet>\n".to_string());
+    }
+    let content = fs::read_to_string(path)?;
+    let lines = content.lines().collect::<Vec<_>>();
+    let start = lines.len().saturating_sub(max_lines);
+    Ok(lines[start..].join("\n"))
+}
+
+#[cfg(unix)]
+fn set_executable(path: &Path) -> Result<()> {
+    use std::os::unix::fs::PermissionsExt;
+    let mut permissions = fs::metadata(path)?.permissions();
+    permissions.set_mode(0o755);
+    fs::set_permissions(path, permissions)?;
+    Ok(())
+}
+
+#[cfg(not(unix))]
+fn set_executable(_path: &Path) -> Result<()> {
+    Ok(())
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn parses_modes() {
+        assert_eq!(ClusterMode::parse("kind").unwrap(), ClusterMode::Kind);
+        assert_eq!(
+            ClusterMode::parse("minikube-compatible").unwrap(),
+            ClusterMode::Minikube
+        );
+        assert_eq!(
+            ClusterMode::parse("single_node").unwrap(),
+            ClusterMode::SingleNode
+        );
+    }
+
+    #[test]
+    fn validates_profile_names() {
+        assert!(validate_profile_name("dev").is_ok());
+        assert!(validate_profile_name("prod-single.1").is_ok());
+        assert!(validate_profile_name("BadProfile").is_err());
+        assert!(validate_profile_name("../../oops").is_err());
+    }
+
+    #[test]
+    fn deterministic_ports_are_stable_and_windowed() {
+        let first = deterministic_base_port("dev");
+        let second = deterministic_base_port("dev");
+        assert_eq!(first, second);
+        assert!(first >= 35_000);
+        assert!(first <= 55_000);
+        assert_eq!(first % 200, 0);
+    }
+
+    #[test]
+    fn env_round_trip() {
+        let temp = env::temp_dir().join(format!("rusternetes-test-{}", now_unix()));
+        fs::create_dir_all(&temp).unwrap();
+        let path = temp.join("config.env");
+        let cfg = ProfileConfig {
+            profile: "dev".to_string(),
+            mode: ClusterMode::Kind,
+            driver: RuntimeDriver::Docker,
+            profile_type: ProfileType::Development,
+            nodes: 1,
+            ports: PortSet {
+                api: 41_000,
+                registry: 41_001,
+                metrics: 41_002,
+                service_start: 41_100,
+                service_end: 41_199,
+            },
+            node_image: "rusternetes/local-node:dev".to_string(),
+            runtime_socket: Some(PathBuf::from("/var/run/docker.sock")),
+            created_unix: 1,
+        };
+        cfg.write(&path).unwrap();
+        let read = ProfileConfig::read(&path).unwrap();
+        assert_eq!(read.profile, cfg.profile);
+        assert_eq!(read.mode, cfg.mode);
+        assert_eq!(read.ports.api, cfg.ports.api);
+        fs::remove_dir_all(&temp).unwrap();
+    }
+}
