+    pub fn addons(&self, profile: &str) -> Result<Vec<AddonStatus>> {
+        let (_cfg, paths) = self.read_existing(profile)?;
+        let registry_enabled = paths.addon_dir.join("registry.env").exists();
+        let dashboard_enabled = paths.addon_dir.join("dashboard.env").exists();
+        Ok(vec![
+            AddonStatus {
+                name: "registry".to_string(),
+                support: AddonSupport::Supported,
+                enabled: registry_enabled,
+                message: if registry_enabled {
+                    "local registry container is configured for this profile".to_string()
+                } else {
+                    "starts a registry:2 container on the deterministic profile registry port".to_string()
+                },
+            },
+            AddonStatus {
+                name: "dashboard".to_string(),
+                support: AddonSupport::PartiallySupported,
+                enabled: dashboard_enabled,
+                message: "uses the existing Rūsternetes web console served by the API server when console assets are present".to_string(),
+            },
+            AddonStatus {
+                name: "ingress".to_string(),
+                support: AddonSupport::Unsupported,
+                enabled: false,
+                message: "ingress command path exists, but no ingress controller image/bootstrap is bundled yet".to_string(),
+            },
+            AddonStatus {
+                name: "metrics".to_string(),
+                support: AddonSupport::Planned,
+                enabled: false,
+                message: "metrics API/server add-on wiring is reserved for a future controller-backed implementation".to_string(),
+            },
+        ])
+    }
+
+    pub fn enable_addon(&self, profile: &str, addon: &str) -> Result<String> {
+        let addon = normalize(addon);
+        let (cfg, paths) = self.read_existing(profile)?;
+        match addon.as_str() {
+            "registry" | "local-registry" => self.enable_registry(&cfg, &paths),
+            "dashboard" | "console" | "web-console" => self.enable_dashboard(&cfg, &paths),
+            "ingress" => Err(ClusterError::Unsupported(
+                "ingress is not enabled yet because this release does not bundle an ingress controller or patch Service/Ingress routing rules. The API entry point exists so a future controller can be added without rewriting CLI/desktop code.".to_string(),
+            )),
+            "metrics" => Err(ClusterError::Unsupported(
+                "metrics add-on is planned but not wired in this release; no success is reported until the metrics API bootstrap is implemented".to_string(),
+            )),
+            other => Err(ClusterError::InvalidArgument(format!(
+                "unknown addon '{other}'. Valid addons: registry, dashboard, ingress, metrics"
+            ))),
+        }
+    }
+
+    pub fn disable_addon(&self, profile: &str, addon: &str) -> Result<String> {
+        let addon = normalize(addon);
+        let (cfg, paths) = self.read_existing(profile)?;
+        match addon.as_str() {
+            "registry" | "local-registry" => {
+                let runtime = Runtime::detect(Some(cfg.driver))?;
+                run_runtime(
+                    &runtime,
+                    &["rm", "-f", &registry_container_name(profile)],
+                    &paths.manager_log,
+                    CommandMode::AllowFailure,
+                )?;
+                remove_file_if_exists(&paths.addon_dir.join("registry.env"))?;
+                Ok("registry add-on disabled".to_string())
+            }
+            "dashboard" | "console" | "web-console" => {
+                remove_file_if_exists(&paths.addon_dir.join("dashboard.env"))?;
+                Ok("dashboard add-on marker removed; recreate the cluster to change console asset mounting".to_string())
+            }
+            "ingress" | "metrics" => Err(ClusterError::Unsupported(format!(
+                "addon '{addon}' is not enabled in this release"
+            ))),
+            other => Err(ClusterError::InvalidArgument(format!(
+                "unknown addon '{other}'. Valid addons: registry, dashboard, ingress, metrics"
+            ))),
+        }
+    }
