+        let restore = paths.hooks_dir.join("restore.sh");
+        fs::write(
+            &backup,
+            format!(
+                "#!/usr/bin/env sh\nset -eu\nPROFILE_DIR=\"{}\"\nSTAMP=$(date +%Y%m%d%H%M%S)\nmkdir -p \"$PROFILE_DIR/backups\"\ncp \"$PROFILE_DIR/storage/rusternetes.db\" \"$PROFILE_DIR/backups/rusternetes-$STAMP.db\"\necho \"backup written to $PROFILE_DIR/backups/rusternetes-$STAMP.db\"\n",
+                paths.profile_dir.display()
+            ),
+        )?;
+        fs::write(
+            &restore,
+            format!(
+                "#!/usr/bin/env sh\nset -eu\nif [ $# -ne 1 ]; then echo 'usage: restore.sh /path/to/rusternetes.db' >&2; exit 2; fi\nPROFILE_DIR=\"{}\"\ncp \"$1\" \"$PROFILE_DIR/storage/rusternetes.db\"\necho 'restore staged; restart the profile container to load the database'\n",
+                paths.profile_dir.display()
+            ),
+        )?;
+        set_executable(&backup)?;
+        set_executable(&restore)?;
+        fs::write(
+            paths.hooks_dir.join("upgrade-policy.env"),
+            format!(
+                "profile={}\npolicy=backup-before-recreate\ncontrolled_upgrade=true\ncreated_unix={}\n",
+                cfg.profile,
+                now_unix()
+            ),
+        )?;
+        Ok(())
+    }
