diff --git a/desktop/src/main.ts b/desktop/src/main.ts
new file mode 100644
index 0000000..2f91438
--- /dev/null
+++ b/desktop/src/main.ts
@@ -0,0 +1,184 @@
+import { invoke } from "@tauri-apps/api/core";
+import "./styles.css";
+
+type ClusterStatus = {
+  profile: string;
+  mode: string;
+  driver: string;
+  profile_type: string;
+  phase: string;
+  api_endpoint: string;
+  kubeconfig_path: string;
+  profile_dir: string;
+  message: string;
+};
+
+type AddonStatus = {
+  name: string;
+  support: string;
+  enabled: boolean;
+  message: string;
+};
+
+const app = document.querySelector<HTMLDivElement>("#app")!;
+
+app.innerHTML = `
+  <main class="shell">
+    <section class="hero">
+      <div>
+        <p class="eyebrow">Rūsternetes Desktop</p>
+        <h1>Local clusters without duplicated orchestration.</h1>
+        <p class="lede">Create kind-compatible, minikube-compatible, and production single-node Rūsternetes profiles from the same manager used by the CLI.</p>
+      </div>
+      <button id="refresh" class="ghost">Refresh status</button>
+    </section>
+
+    <section class="panel grid">
+      <label>Profile<input id="profile" value="dev" /></label>
+      <label>Mode
+        <select id="mode">
+          <option value="kind">kind-compatible</option>
+          <option value="minikube">minikube-compatible</option>
+          <option value="single-node">production single-node</option>
+        </select>
+      </label>
+      <label>Runtime
+        <select id="driver">
+          <option value="docker">Docker</option>
+          <option value="podman">Podman</option>
+          <option value="auto">Auto</option>
+        </select>
+      </label>
+      <label>Profile type
+        <select id="profileType">
+          <option value="development">development</option>
+          <option value="production">production</option>
+        </select>
+      </label>
+    </section>
+
+    <section class="actions">
+      <button id="create">Create</button>
+      <button id="start">Start</button>
+      <button id="stop">Stop</button>
+      <button id="reset">Reset</button>
+      <button id="delete" class="danger">Delete</button>
+      <button id="smoke" class="secondary">Run smoke test</button>
+    </section>
+
+    <section class="panel status-panel">
+      <div class="status-header">
+        <h2>Status</h2>
+        <button id="copyKube" class="ghost">Copy kubeconfig export</button>
+      </div>
+      <pre id="status">No status loaded yet.</pre>
+    </section>
+
+    <section class="panel addons-panel">
+      <div class="status-header">
+        <h2>Add-ons</h2>
+        <div class="inline">
+          <select id="addonName">
+            <option value="registry">registry</option>
+            <option value="dashboard">dashboard</option>
+            <option value="ingress">ingress</option>
+            <option value="metrics">metrics</option>
+          </select>
+          <button id="enableAddon">Enable</button>
+          <button id="disableAddon" class="secondary">Disable</button>
+        </div>
+      </div>
+      <div id="addons" class="addons"></div>
+    </section>
+
+    <section class="panel logs-panel">
+      <div class="status-header">
+        <h2>Logs</h2>
+        <div class="inline">
+          <button id="loadLogs" class="secondary">Load logs</button>
+          <button id="openConsole" class="ghost">Open web console</button>
+        </div>
+      </div>
+      <pre id="logs">Logs will appear here.</pre>
+    </section>
+  </main>
+`;
+
+const get = (id: string) => document.querySelector<HTMLInputElement | HTMLSelectElement>(`#${id}`)!;
+const profile = () => get("profile").value.trim() || "dev";
+const mode = () => get("mode").value;
+const driver = () => get("driver").value;
+const profileType = () => get("profileType").value;
+const statusEl = document.querySelector<HTMLPreElement>("#status")!;
+const logsEl = document.querySelector<HTMLPreElement>("#logs")!;
+const addonsEl = document.querySelector<HTMLDivElement>("#addons")!;
+
+function renderStatus(status: ClusterStatus) {
+  statusEl.textContent = [
+    `profile: ${status.profile}`,
+    `mode: ${status.mode}`,
+    `driver: ${status.driver}`,
+    `profile_type: ${status.profile_type}`,
+    `phase: ${status.phase}`,
+    `api: ${status.api_endpoint}`,
+    `kubeconfig: ${status.kubeconfig_path}`,
+    `profile_dir: ${status.profile_dir}`,
+    `export KUBECONFIG="${status.kubeconfig_path}"`,
+    status.message ? `message: ${status.message}` : ""
+  ].filter(Boolean).join("\n");
+}
+
+function renderAddons(addons: AddonStatus[]) {
+  addonsEl.innerHTML = addons.map((addon) => `
+    <article class="addon-card ${addon.enabled ? "enabled" : ""}">
+      <div>
+        <strong>${addon.name}</strong>
+        <span>${addon.support}</span>
+      </div>
+      <p>${addon.message}</p>
+    </article>
+  `).join("");
+}
+
+async function refresh() {
+  try {
+    const status = await invoke<ClusterStatus>("cluster_status", { profile: profile() });
+    renderStatus(status);
+    const addons = await invoke<AddonStatus[]>("addons_list", { profile: profile() });
+    renderAddons(addons);
+  } catch (error) {
+    statusEl.textContent = String(error);
+  }
+}
+
+async function runAction<T>(action: () => Promise<T>, after: (value: T) => void = () => undefined) {
+  statusEl.textContent = "Running...";
+  try {
+    const result = await action();
+    after(result);
+    await refresh();
+  } catch (error) {
+    statusEl.textContent = String(error);
+  }
+}
+
+document.querySelector("#create")!.addEventListener("click", () => runAction(
+  () => invoke<ClusterStatus>("create_cluster", { profile: profile(), mode: mode(), driver: driver(), profileType: profileType() }),
+  renderStatus
+));
+document.querySelector("#start")!.addEventListener("click", () => runAction(() => invoke<ClusterStatus>("cluster_start", { profile: profile() }), renderStatus));
+document.querySelector("#stop")!.addEventListener("click", () => runAction(() => invoke<ClusterStatus>("cluster_stop", { profile: profile() }), renderStatus));
+document.querySelector("#reset")!.addEventListener("click", () => runAction(() => invoke<ClusterStatus>("cluster_reset", { profile: profile() }), renderStatus));
+document.querySelector("#delete")!.addEventListener("click", () => runAction(() => invoke<string>("cluster_delete", { profile: profile() }), (msg) => { statusEl.textContent = msg; }));
+document.querySelector("#refresh")!.addEventListener("click", refresh);
+document.querySelector("#loadLogs")!.addEventListener("click", async () => { logsEl.textContent = await invoke<string>("cluster_logs", { profile: profile() }); });
+document.querySelector("#enableAddon")!.addEventListener("click", () => runAction(() => invoke<string>("addon_enable", { profile: profile(), addon: get("addonName").value }), (msg) => { logsEl.textContent = msg; }));
+document.querySelector("#disableAddon")!.addEventListener("click", () => runAction(() => invoke<string>("addon_disable", { profile: profile(), addon: get("addonName").value }), (msg) => { logsEl.textContent = msg; }));
+document.querySelector("#smoke")!.addEventListener("click", async () => { logsEl.textContent = await invoke<string>("smoke_test", { profile: profile() }); });
+document.querySelector("#openConsole")!.addEventListener("click", async () => { window.open(await invoke<string>("console_url", { profile: profile() }), "_blank"); });
+document.querySelector("#copyKube")!.addEventListener("click", async () => {
+  const path = await invoke<string>("kubeconfig_path", { profile: profile() });
+  await navigator.clipboard.writeText(`export KUBECONFIG="${path}"`);
+});
+
+refresh();
