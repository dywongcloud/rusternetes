+#[derive(Clone, Debug)]
+struct ProfileConfig {
+    profile: String,
+    mode: ClusterMode,
+    driver: RuntimeDriver,
+    profile_type: ProfileType,
+    nodes: usize,
+    ports: PortSet,
+    node_image: String,
+    runtime_socket: Option<PathBuf>,
+    created_unix: u64,
+}
+
+impl ProfileConfig {
+    fn write(&self, path: &Path) -> Result<()> {
+        let socket = self
+            .runtime_socket
+            .as_ref()
+            .map(|p| p.display().to_string())
+            .unwrap_or_default();
+        let content = format!(
+            "profile={}\nmode={}\ndriver={}\nprofile_type={}\nnodes={}\napi_port={}\nregistry_port={}\nmetrics_port={}\nservice_start_port={}\nservice_end_port={}\nnode_image={}\nruntime_socket={}\ncreated_unix={}\n",
+            self.profile,
+            self.mode,
+            self.driver,
+            self.profile_type,
+            self.nodes,
+            self.ports.api,
+            self.ports.registry,
+            self.ports.metrics,
+            self.ports.service_start,
+            self.ports.service_end,
+            self.node_image,
+            socket,
+            self.created_unix
+        );
+        fs::write(path, content)?;
+        Ok(())
+    }
+
+    fn read(path: &Path) -> Result<Self> {
+        let values = read_env_file(path)?;
+        let profile = required(&values, "profile")?.to_string();
+        let mode = ClusterMode::parse(required(&values, "mode")?)?;
+        let driver = RuntimeDriver::parse(required(&values, "driver")?)?;
+        let profile_type = ProfileType::parse(required(&values, "profile_type")?)?;
+        let nodes = required(&values, "nodes")?
+            .parse::<usize>()
+            .map_err(|err| {
+                ClusterError::Parse(format!("invalid nodes in {}: {err}", path.display()))
+            })?;
+        let ports = PortSet {
+            api: parse_port(&values, "api_port", path)?,
+            registry: parse_port(&values, "registry_port", path)?,
+            metrics: parse_port(&values, "metrics_port", path)?,
+            service_start: parse_port(&values, "service_start_port", path)?,
+            service_end: parse_port(&values, "service_end_port", path)?,
+        };
+        let node_image = required(&values, "node_image")?.to_string();
+        let runtime_socket = values
+            .get("runtime_socket")
+            .filter(|value| !value.is_empty())
+            .map(PathBuf::from);
+        let created_unix = values
+            .get("created_unix")
+            .and_then(|value| value.parse::<u64>().ok())
+            .unwrap_or(0);
+        Ok(Self {
+            profile,
+            mode,
+            driver,
+            profile_type,
+            nodes,
+            ports,
+            node_image,
+            runtime_socket,
+            created_unix,
+        })
+    }
+}
