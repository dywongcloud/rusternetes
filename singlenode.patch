+#[derive(Clone, Debug)]
+struct Runtime {
+    driver: RuntimeDriver,
+    executable: String,
+    socket: Option<PathBuf>,
+}
+
+impl Runtime {
+    fn detect(driver: Option<RuntimeDriver>) -> Result<Self> {
+        match driver {
+            Some(RuntimeDriver::Docker) => Self::detect_one(RuntimeDriver::Docker),
+            Some(RuntimeDriver::Podman) => Self::detect_one(RuntimeDriver::Podman),
+            None => Self::detect_one(RuntimeDriver::Docker)
+                .or_else(|_| Self::detect_one(RuntimeDriver::Podman)),
+        }
+    }
+
+    fn detect_one(driver: RuntimeDriver) -> Result<Self> {
+        let executable = driver.as_str().to_string();
+        if !command_exists(&executable) {
+            return Err(ClusterError::RuntimeUnavailable(format!(
+                "{} executable was not found in PATH",
+                driver
+            )));
+        }
+        run_program(
+            &executable,
+            &["--version"],
+            Path::new("/dev/null"),
+            CommandMode::RequireSuccess,
+        )?;
+        Ok(Self {
+            driver,
+            executable,
+            socket: detect_socket(driver),
+        })
+    }
+}
