+    fn read_existing(&self, profile: &str) -> Result<(ProfileConfig, ProfilePaths)> {
+        validate_profile_name(profile)?;
+        let paths = ProfilePaths::new(&self.root, profile);
+        if !paths.config_file.exists() {
+            return Err(ClusterError::ProfileNotFound(profile.to_string()));
+        }
+        let cfg = ProfileConfig::read(&paths.config_file)?;
+        Ok((cfg, paths))
+    }
+
+    fn allocate_ports(&self, profile: &str) -> Result<PortSet> {
+        fs::create_dir_all(self.root.join("profiles"))?;
+        let mut used = Vec::new();
+        let profiles_dir = self.root.join("profiles");
+        if profiles_dir.exists() {
+            for entry in fs::read_dir(&profiles_dir)? {
+                let entry = entry?;
+                if !entry.file_type()?.is_dir() {
+                    continue;
+                }
+                let name = entry.file_name().to_string_lossy().to_string();
+                if name == profile {
+                    continue;
+                }
+                let config = entry.path().join("config.env");
+                if config.exists() {
+                    if let Ok(cfg) = ProfileConfig::read(&config) {
+                        used.extend_from_slice(&cfg.ports.values());
+                    }
+                }
+            }
+        }
+        let mut base = deterministic_base_port(profile);
+        for _ in 0..1000 {
+            let ports = PortSet {
+                api: base,
+                registry: base + 1,
+                metrics: base + 2,
+                service_start: base + 100,
+                service_end: base + 199,
+            };
+            let collision = ports
+                .values()
+                .into_iter()
+                .any(|port| used.contains(&port) || !port_available(port));
+            if !collision {
+                return Ok(ports);
+            }
+            base = next_base(base);
+        }
+        Err(ClusterError::RuntimeUnavailable(
+            "could not find an available deterministic port window after 1000 attempts".to_string(),
+        ))
+    }
+
+    fn ensure_node_image(
+        &self,
+        runtime: &Runtime,
+        cfg: &ProfileConfig,
+        repo_root: &Path,
+        log: &Path,
+    ) -> Result<()> {
+        let image_exists = run_runtime(
+            runtime,
+            &["image", "inspect", &cfg.node_image],
+            log,
+            CommandMode::AllowFailure,
+        )
+        .is_ok();
+        if image_exists {
+            append_log(log, &format!("node image exists: {}\n", cfg.node_image))?;
+            return Ok(());
+        }
+        if env::var("RUSTERNETES_SKIP_IMAGE_BUILD").ok().as_deref() == Some("1") {
+            return Err(ClusterError::RuntimeUnavailable(format!(
+                "node image '{}' was not found and RUSTERNETES_SKIP_IMAGE_BUILD=1 is set",
+                cfg.node_image
+            )));
+        }
+        let dockerfile = repo_root.join("docker/local-node.Dockerfile");
+        if !dockerfile.exists() {
+            return Err(ClusterError::RuntimeUnavailable(format!(
+                "node image '{}' does not exist and build file {} was not found",
+                cfg.node_image,
+                dockerfile.display()
+            )));
+        }
+        run_runtime(
+            runtime,
+            &[
+                "build",
+                "-f",
+                &dockerfile.display().to_string(),
+                "-t",
+                &cfg.node_image,
+                &repo_root.display().to_string(),
+            ],
+            log,
+            CommandMode::RequireSuccess,
+        )?;
+        Ok(())
+    }
