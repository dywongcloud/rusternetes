+//! Shared Rūsternetes local-cluster orchestration.
+//!
+//! This crate is intentionally dependency-light so it can be reused by the CLI,
+//! smoke scripts, CI, and the Tauri desktop app without duplicating cluster
+//! lifecycle logic.
+
+use std::collections::BTreeMap;
+use std::env;
+use std::error::Error as StdError;
+use std::fmt::{self, Display};
+use std::fs::{self, File, OpenOptions};
+use std::io::{self, Read, Write};
+use std::net::{SocketAddr, TcpStream};
+use std::path::{Path, PathBuf};
+use std::process::{Command, Output};
+use std::time::{Duration, SystemTime, UNIX_EPOCH};
+
+pub type Result<T> = std::result::Result<T, ClusterError>;
+
+#[derive(Debug)]
+pub enum ClusterError {
+    Io(io::Error),
+    InvalidArgument(String),
+    RuntimeUnavailable(String),
+    CommandFailed {
+        command: String,
+        status: Option<i32>,
+        stdout: String,
+        stderr: String,
+    },
+    Unsupported(String),
+    ProfileNotFound(String),
+    Parse(String),
+}
+
+impl Display for ClusterError {
+    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
+        match self {
+            ClusterError::Io(err) => write!(f, "I/O error: {err}"),
+            ClusterError::InvalidArgument(msg) => write!(f, "invalid argument: {msg}"),
+            ClusterError::RuntimeUnavailable(msg) => write!(f, "runtime unavailable: {msg}"),
+            ClusterError::CommandFailed {
+                command,
+                status,
+                stdout,
+                stderr,
+            } => write!(
+                f,
+                "command failed: {command}\nstatus: {}\nstdout:\n{}\nstderr:\n{}",
+                status
+                    .map(|code| code.to_string())
+                    .unwrap_or_else(|| "terminated by signal".to_string()),
+                stdout.trim(),
+                stderr.trim()
+            ),
+            ClusterError::Unsupported(msg) => write!(f, "unsupported: {msg}"),
+            ClusterError::ProfileNotFound(profile) => write!(
+                f,
+                "profile '{profile}' was not found; create it first with `rusternetes cluster create --profile {profile}`"
+            ),
+            ClusterError::Parse(msg) => write!(f, "parse error: {msg}"),
+        }
+    }
+}
+
+impl StdError for ClusterError {}
+
+impl From<io::Error> for ClusterError {
+    fn from(value: io::Error) -> Self {
+        ClusterError::Io(value)
+    }
+}
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub enum ClusterMode {
+    Kind,
+    Minikube,
+    SingleNode,
+}
+
+impl ClusterMode {
+    pub fn parse(value: &str) -> Result<Self> {
+        match normalize(value).as_str() {
+            "kind" | "kind-compatible" => Ok(Self::Kind),
+            "minikube" | "minikube-compatible" => Ok(Self::Minikube),
+            "single-node" | "single_node" | "production" | "prod-single" => Ok(Self::SingleNode),
+            other => Err(ClusterError::InvalidArgument(format!(
+                "unknown cluster mode '{other}'. Valid modes: kind, minikube, single-node"
+            ))),
+        }
+    }
+
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::Kind => "kind",
+            Self::Minikube => "minikube",
+            Self::SingleNode => "single-node",
+        }
+    }
+
+    pub fn description(self) -> &'static str {
+        match self {
+            Self::Kind => "kind-compatible node-container profile",
+            Self::Minikube => "minikube-compatible single-profile local cluster",
+            Self::SingleNode => "production single-node Rūsternetes profile",
+        }
+    }
+}
+
+impl Display for ClusterMode {
+    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
+        f.write_str(self.as_str())
+    }
+}
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub enum RuntimeDriver {
+    Docker,
+    Podman,
+}
+
+impl RuntimeDriver {
+    pub fn parse(value: &str) -> Result<Self> {
+        match normalize(value).as_str() {
+            "docker" => Ok(Self::Docker),
+            "podman" => Ok(Self::Podman),
+            other => Err(ClusterError::InvalidArgument(format!(
+                "unknown runtime driver '{other}'. Valid drivers: docker, podman"
+            ))),
+        }
+    }
+
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::Docker => "docker",
+            Self::Podman => "podman",
+        }
+    }
+}
+
+impl Display for RuntimeDriver {
+    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
+        f.write_str(self.as_str())
+    }
+}
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub enum ProfileType {
+    Development,
+    Production,
+}
+
+impl ProfileType {
+    pub fn parse(value: &str) -> Result<Self> {
+        match normalize(value).as_str() {
+            "dev" | "development" => Ok(Self::Development),
+            "prod" | "production" | "prod-single" => Ok(Self::Production),
+            other => Err(ClusterError::InvalidArgument(format!(
+                "unknown profile type '{other}'. Valid profile types: development, production"
+            ))),
+        }
+    }
+
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::Development => "development",
+            Self::Production => "production",
+        }
+    }
+}
+
+impl Display for ProfileType {
+    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
+        f.write_str(self.as_str())
+    }
+}
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub enum ClusterPhase {
+    NotCreated,
+    Creating,
+    Running,
+    Stopped,
+    Error,
+    Unknown,
+}
+
+impl ClusterPhase {
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::NotCreated => "not-created",
+            Self::Creating => "creating",
+            Self::Running => "running",
+            Self::Stopped => "stopped",
+            Self::Error => "error",
+            Self::Unknown => "unknown",
+        }
+    }
+}
+
+impl Display for ClusterPhase {
+    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
+        f.write_str(self.as_str())
+    }
+}
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub enum AddonSupport {
+    Supported,
+    PartiallySupported,
+    Unsupported,
+    Planned,
+}
+
+impl AddonSupport {
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::Supported => "supported",
+            Self::PartiallySupported => "partially-supported",
+            Self::Unsupported => "unsupported",
+            Self::Planned => "planned",
+        }
+    }
+}
+
+impl Display for AddonSupport {
+    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
+        f.write_str(self.as_str())
+    }
+}
+
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub struct AddonStatus {
+    pub name: String,
+    pub support: AddonSupport,
+    pub enabled: bool,
+    pub message: String,
+}
+
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub struct NodeStatus {
+    pub name: String,
+    pub role: String,
+    pub container: String,
+    pub runtime_status: String,
+}
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub struct PortSet {
+    pub api: u16,
+    pub registry: u16,
+    pub metrics: u16,
+    pub service_start: u16,
+    pub service_end: u16,
+}
+
+impl PortSet {
+    pub fn values(self) -> [u16; 5] {
+        [
+            self.api,
+            self.registry,
+            self.metrics,
+            self.service_start,
+            self.service_end,
+        ]
+    }
+}
+
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub struct ClusterStatus {
+    pub profile: String,
+    pub mode: ClusterMode,
+    pub driver: RuntimeDriver,
+    pub profile_type: ProfileType,
+    pub phase: ClusterPhase,
+    pub api_endpoint: String,
+    pub kubeconfig_path: PathBuf,
+    pub profile_dir: PathBuf,
+    pub ports: PortSet,
+    pub nodes: Vec<NodeStatus>,
+    pub addons: Vec<AddonStatus>,
+    pub message: String,
+}
+
+impl ClusterStatus {
+    pub fn export_command(&self) -> String {
+        format!("export KUBECONFIG=\"{}\"", self.kubeconfig_path.display())
+    }
+}
+
+#[derive(Clone, Debug)]
+pub struct CreateOptions {
+    pub profile: String,
+    pub mode: ClusterMode,
+    pub driver: Option<RuntimeDriver>,
+    pub profile_type: ProfileType,
+    pub nodes: usize,
+    pub node_image: Option<String>,
+    pub repo_root: Option<PathBuf>,
+    pub wait: bool,
+    pub force: bool,
+}
+
+impl Default for CreateOptions {
+    fn default() -> Self {
+        Self {
+            profile: "dev".to_string(),
+            mode: ClusterMode::Kind,
+            driver: None,
+            profile_type: ProfileType::Development,
+            nodes: 1,
+            node_image: None,
+            repo_root: None,
+            wait: true,
+            force: false,
+        }
+    }
+}
+
+#[derive(Debug)]
+pub struct ClusterManager {
+    root: PathBuf,
+    repo_root: PathBuf,
+}
+
+impl ClusterManager {
+    pub fn new(root: impl Into<PathBuf>, repo_root: impl Into<PathBuf>) -> Self {
+        Self {
+            root: root.into(),
+            repo_root: repo_root.into(),
+        }
+    }
+
+    pub fn default_paths() -> Result<Self> {
+        let cwd = env::current_dir()?;
+        let root = env::var_os("RUSTERNETES_HOME")
+            .map(PathBuf::from)
+            .unwrap_or_else(|| cwd.join(".rusternetes"));
+        let repo_root = env::var_os("RUSTERNETES_REPO_ROOT")
+            .map(PathBuf::from)
+            .unwrap_or(cwd);
+        Ok(Self { root, repo_root })
+    }
+
+    pub fn root(&self) -> &Path {
+        &self.root
+    }
+
+    pub fn repo_root(&self) -> &Path {
+        &self.repo_root
+    }
+
+    pub fn create(&self, options: CreateOptions) -> Result<ClusterStatus> {
+        validate_profile_name(&options.profile)?;
+        if options.nodes == 0 {
+            return Err(ClusterError::InvalidArgument(
+                "node count must be at least 1".to_string(),
+            ));
+        }
+        if options.mode != ClusterMode::Kind && options.nodes != 1 {
+            return Err(ClusterError::Unsupported(format!(
+                "{} mode currently supports one local node; multi-node is prepared for kind mode only",
+                options.mode
+            )));
+        }
+
+        let repo_root = options
+            .repo_root
+            .clone()
+            .unwrap_or_else(|| self.repo_root.clone());
+        let runtime = Runtime::detect(options.driver)?;
+        let profile_paths = ProfilePaths::new(&self.root, &options.profile);
+
+        if profile_paths.config_file.exists() && !options.force {
+            let status = self.status(&options.profile)?;
+            if status.phase == ClusterPhase::Running {
+                return Ok(status);
+            }
+        }
+
+        if options.force && profile_paths.config_file.exists() {
+            self.delete(&options.profile)?;
+        } else {
+            fs::create_dir_all(&profile_paths.profile_dir)?;
+        }
+
+        profile_paths.ensure()?;
+        let ports = self.allocate_ports(&options.profile)?;
+        let image = options
+            .node_image
+            .clone()
+            .or_else(|| env::var("RUSTERNETES_NODE_IMAGE").ok())
+            .unwrap_or_else(|| "rusternetes/local-node:dev".to_string());
+        let mut cfg = ProfileConfig {
+            profile: options.profile.clone(),
+            mode: options.mode,
+            driver: runtime.driver,
+            profile_type: options.profile_type,
+            nodes: options.nodes,
+            ports,
+            node_image: image,
+            runtime_socket: runtime.socket.clone(),
+            created_unix: now_unix(),
+        };
+        if cfg.mode == ClusterMode::SingleNode && cfg.profile_type != ProfileType::Production {
+            cfg.profile_type = ProfileType::Production;
+        }
+        cfg.write(&profile_paths.config_file)?;
+        write_state(
+            &profile_paths.state_file,
+            ClusterPhase::Creating,
+            "creating",
+        )?;
+        append_log(
+            &profile_paths.manager_log,
+            &format!(
+                "creating profile={} mode={} driver={} profile_type={} api_port={}\n",
+                cfg.profile, cfg.mode, cfg.driver, cfg.profile_type, cfg.ports.api
+            ),
+        )?;
+
+        if cfg.profile_type == ProfileType::Production {
+            self.ensure_production_certificates(&profile_paths, &cfg)?;
+            self.write_production_hooks(&profile_paths, &cfg)?;
+        }
+
+        self.ensure_node_image(&runtime, &cfg, &repo_root, &profile_paths.manager_log)?;
+        self.ensure_network(&runtime, &cfg, &profile_paths.manager_log)?;
+        self.remove_node_containers(&runtime, &cfg, &profile_paths.manager_log)?;
+        self.run_node_container(&runtime, &cfg, &profile_paths, &profile_paths.manager_log)?;
+        self.write_kubeconfig_for(&profile_paths, &cfg)?;
+
+        if options.wait {
+            self.wait_for_api(&cfg, Duration::from_secs(90))?;
+        }
+
+        write_state(&profile_paths.state_file, ClusterPhase::Running, "running")?;
+        self.status(&cfg.profile)
+    }
+
+    pub fn start(&self, profile: &str) -> Result<ClusterStatus> {
+        let (cfg, paths) = self.read_existing(profile)?;
+        let runtime = Runtime::detect(Some(cfg.driver))?;
+        for name in node_container_names(&cfg) {
+            run_runtime(
+                &runtime,
+                &["start", &name],
+                &paths.manager_log,
+                CommandMode::AllowFailure,
+            )?;
+        }
+        if paths.addon_dir.join("registry.env").exists() {
+            let registry = registry_container_name(profile);
+            run_runtime(
+                &runtime,
+                &["start", &registry],
+                &paths.manager_log,
+                CommandMode::AllowFailure,
+            )?;
+        }
+        write_state(&paths.state_file, ClusterPhase::Running, "started")?;
+        self.status(profile)
+    }
+
+    pub fn stop(&self, profile: &str) -> Result<ClusterStatus> {
+        let (cfg, paths) = self.read_existing(profile)?;
+        let runtime = Runtime::detect(Some(cfg.driver))?;
+        for name in node_container_names(&cfg) {
+            run_runtime(
+                &runtime,
+                &["stop", &name],
+                &paths.manager_log,
+                CommandMode::AllowFailure,
+            )?;
+        }
+        if paths.addon_dir.join("registry.env").exists() {
+            let registry = registry_container_name(profile);
+            run_runtime(
+                &runtime,
+                &["stop", &registry],
+                &paths.manager_log,
+                CommandMode::AllowFailure,
+            )?;
+        }
+        write_state(&paths.state_file, ClusterPhase::Stopped, "stopped")?;
+        self.status(profile)
+    }
+
+    pub fn delete(&self, profile: &str) -> Result<()> {
+        let paths = ProfilePaths::new(&self.root, profile);
+        if !paths.config_file.exists() {
+            return Ok(());
+        }
+        let cfg = ProfileConfig::read(&paths.config_file)?;
+        let runtime = Runtime::detect(Some(cfg.driver))?;
+        self.collect_container_logs(&runtime, &cfg, &paths).ok();
+        self.remove_node_containers(&runtime, &cfg, &paths.manager_log)?;
+        let registry = registry_container_name(profile);
+        run_runtime(
+            &runtime,
+            &["rm", "-f", &registry],
+            &paths.manager_log,
+            CommandMode::AllowFailure,
+        )?;
+        run_runtime(
+            &runtime,
+            &["network", "rm", &network_name(profile)],
+            &paths.manager_log,
+            CommandMode::AllowFailure,
+        )?;
+        if paths.profile_dir.exists() {
+            fs::remove_dir_all(&paths.profile_dir)?;
+        }
+        Ok(())
+    }
+
+    pub fn reset(&self, profile: &str) -> Result<ClusterStatus> {
+        let (cfg, _paths) = self.read_existing(profile)?;
+        let options = CreateOptions {
+            profile: cfg.profile.clone(),
+            mode: cfg.mode,
+            driver: Some(cfg.driver),
+            profile_type: cfg.profile_type,
+            nodes: cfg.nodes,
+            node_image: Some(cfg.node_image.clone()),
+            repo_root: Some(self.repo_root.clone()),
+            wait: true,
+            force: true,
+        };
+        self.create(options)
+    }
+
+    pub fn status(&self, profile: &str) -> Result<ClusterStatus> {
+        let (cfg, paths) = self.read_existing(profile)?;
+        let runtime = Runtime::detect(Some(cfg.driver));
+        let mut nodes = Vec::new();
+        let mut phase = read_phase(&paths.state_file).unwrap_or(ClusterPhase::Unknown);
+        let message;
+
+        match runtime {
+            Ok(runtime) => {
+                let names = node_container_names(&cfg);
+                let mut running_count = 0usize;
+                for (index, name) in names.iter().enumerate() {
+                    let runtime_status =
+                        inspect_container_status(&runtime, name, &paths.manager_log)
+                            .unwrap_or_else(|err| format!("unknown ({err})"));
+                    if runtime_status == "running" {
+                        running_count += 1;
+                    }
+                    nodes.push(NodeStatus {
+                        name: if index == 0 {
+                            format!("{}-control-plane", cfg.profile)
+                        } else {
+                            format!("{}-worker-{index}", cfg.profile)
+                        },
+                        role: if index == 0 {
+                            "control-plane".to_string()
+                        } else {
+                            "worker".to_string()
+                        },
+                        container: name.clone(),
+                        runtime_status,
+                    });
+                }
+                phase = match (running_count, names.len()) {
+                    (0, _) => ClusterPhase::Stopped,
+                    (count, total) if count == total => ClusterPhase::Running,
+                    _ => ClusterPhase::Error,
+                };
+                message = format!("{} node container(s), {running_count} running", names.len());
+            }
+            Err(err) => {
+                nodes = node_container_names(&cfg)
+                    .into_iter()
+                    .enumerate()
+                    .map(|(index, name)| NodeStatus {
+                        name: if index == 0 {
+                            format!("{}-control-plane", cfg.profile)
+                        } else {
+                            format!("{}-worker-{index}", cfg.profile)
+                        },
+                        role: if index == 0 {
+                            "control-plane".to_string()
+                        } else {
+                            "worker".to_string()
+                        },
+                        container: name,
+                        runtime_status: "runtime-unavailable".to_string(),
+                    })
+                    .collect();
+                message = err.to_string();
+            }
+        }
+
+        Ok(ClusterStatus {
+            profile: cfg.profile.clone(),
+            mode: cfg.mode,
+            driver: cfg.driver,
+            profile_type: cfg.profile_type,
+            phase,
+            api_endpoint: api_endpoint(&cfg),
+            kubeconfig_path: paths.kubeconfig_file,
+            profile_dir: paths.profile_dir,
+            ports: cfg.ports,
+            nodes,
+            addons: self.addons(profile)?,
+            message,
+        })
+    }
+
+    pub fn kubeconfig_path(&self, profile: &str) -> Result<PathBuf> {
+        let (cfg, paths) = self.read_existing(profile)?;
+        if !paths.kubeconfig_file.exists() {
+            self.write_kubeconfig_for(&paths, &cfg)?;
+        }
+        Ok(paths.kubeconfig_file)
+    }
