+    pub fn load_image(&self, profile: &str, image: &str) -> Result<String> {
+        if image.trim().is_empty() {
+            return Err(ClusterError::InvalidArgument(
+                "image reference must not be empty".to_string(),
+            ));
+        }
+        let (cfg, paths) = self.read_existing(profile)?;
+        let runtime = Runtime::detect(Some(cfg.driver))?;
+        match cfg.driver {
+            RuntimeDriver::Docker => {
+                run_runtime(
+                    &runtime,
+                    &["image", "inspect", image],
+                    &paths.manager_log,
+                    CommandMode::RequireSuccess,
+                )?;
+            }
+            RuntimeDriver::Podman => {
+                run_runtime(
+                    &runtime,
+                    &["image", "exists", image],
+                    &paths.manager_log,
+                    CommandMode::RequireSuccess,
+                )?;
+            }
+        }
+        fs::create_dir_all(&paths.metadata_dir)?;
+        let mut file = OpenOptions::new()
+            .create(true)
+            .append(true)
+            .open(paths.metadata_dir.join("loaded-images.txt"))?;
+        writeln!(file, "{} {}", now_unix(), image)?;
+        Ok(format!(
+            "image '{image}' is available to profile '{}' through the {} runtime socket mounted into the Rūsternetes node container",
+            cfg.profile, cfg.driver
+        ))
+    }
