+    pub fn logs(&self, profile: &str) -> Result<String> {
+        let (cfg, paths) = self.read_existing(profile)?;
+        if let Ok(runtime) = Runtime::detect(Some(cfg.driver)) {
+            self.collect_container_logs(&runtime, &cfg, &paths).ok();
+        }
+        let mut out = String::new();
+        out.push_str(&format!("manager log: {}\n", paths.manager_log.display()));
+        out.push_str(&format!("node log: {}\n\n", paths.node_log.display()));
+        out.push_str("--- manager.log ---\n");
+        out.push_str(&read_tail(&paths.manager_log, 200)?);
+        out.push_str("\n--- node.log ---\n");
+        out.push_str(&read_tail(&paths.node_log, 400)?);
+        Ok(out)
+    }
