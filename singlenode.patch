+
+fn read_phase(path: &Path) -> Result<ClusterPhase> {
+    if !path.exists() {
+        return Ok(ClusterPhase::Unknown);
+    }
+    let values = read_env_file(path)?;
+    let phase = values
+        .get("phase")
+        .map(|value| value.as_str())
+        .unwrap_or("unknown");
+    match normalize(phase).as_str() {
+        "not-created" => Ok(ClusterPhase::NotCreated),
+        "creating" => Ok(ClusterPhase::Creating),
+        "running" => Ok(ClusterPhase::Running),
+        "stopped" => Ok(ClusterPhase::Stopped),
+        "error" => Ok(ClusterPhase::Error),
+        _ => Ok(ClusterPhase::Unknown),
+    }
+}
+
+fn read_env_file(path: &Path) -> Result<BTreeMap<String, String>> {
+    let mut file = File::open(path)?;
+    let mut content = String::new();
+    file.read_to_string(&mut content)?;
+    let mut values = BTreeMap::new();
+    for (line_number, line) in content.lines().enumerate() {
+        let line = line.trim();
+        if line.is_empty() || line.starts_with('#') {
+            continue;
+        }
+        let Some((key, value)) = line.split_once('=') else {
+            return Err(ClusterError::Parse(format!(
+                "invalid line {} in {}: expected key=value",
+                line_number + 1,
+                path.display()
+            )));
+        };
+        values.insert(key.trim().to_string(), value.trim().to_string());
+    }
+    Ok(values)
+}
+
+fn required<'a>(values: &'a BTreeMap<String, String>, key: &str) -> Result<&'a str> {
+    values
+        .get(key)
+        .map(|value| value.as_str())
+        .ok_or_else(|| ClusterError::Parse(format!("missing required key '{key}'")))
+}
+
+fn parse_port(values: &BTreeMap<String, String>, key: &str, path: &Path) -> Result<u16> {
+    required(values, key)?
+        .parse::<u16>()
+        .map_err(|err| ClusterError::Parse(format!("invalid {key} in {}: {err}", path.display())))
+}
+
+fn validate_profile_name(profile: &str) -> Result<()> {
+    if profile.is_empty() {
+        return Err(ClusterError::InvalidArgument(
+            "profile name must not be empty".to_string(),
+        ));
+    }
+    if profile.len() > 63 {
+        return Err(ClusterError::InvalidArgument(
+            "profile name must be at most 63 characters".to_string(),
+        ));
+    }
+    let valid = profile.chars().all(|ch| {
+        ch.is_ascii_lowercase() || ch.is_ascii_digit() || ch == '-' || ch == '_' || ch == '.'
+    });
+    if !valid {
+        return Err(ClusterError::InvalidArgument(
+            "profile name may only contain lowercase letters, numbers, dash, underscore, and dot"
+                .to_string(),
+        ));
+    }
+    Ok(())
+}
+
+fn deterministic_base_port(profile: &str) -> u16 {
+    let mut hash: u64 = 0xcbf29ce484222325;
+    for byte in profile.as_bytes() {
+        hash ^= u64::from(*byte);
+        hash = hash.wrapping_mul(0x100000001b3);
+    }
+    let base = 35_000 + (hash % 20_000) as u16;
+    base - (base % 200)
+}
+
+fn next_base(base: u16) -> u16 {
+    let next = base.saturating_add(200);
+    if next > 54_000 {
+        35_000
+    } else {
+        next
+    }
+}
