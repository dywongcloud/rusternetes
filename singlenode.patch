+fn write_state(path: &Path, phase: ClusterPhase, message: &str) -> Result<()> {
+    let content = format!(
+        "phase={}\nmessage={}\nupdated_unix={}\n",
+        phase,
+        sanitize_env_value(message),
+        now_unix()
+    );
