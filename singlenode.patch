+++ b/desktop/src-tauri/src/main.rs
@@ -0,0 +1,198 @@
+use rusternetes_cluster_manager::{
+    AddonStatus, ClusterManager, ClusterMode, ClusterStatus, CreateOptions, ProfileType,
+    RuntimeDriver,
+};
+use serde::Serialize;
+use std::path::PathBuf;
+
+#[derive(Serialize)]
+struct DesktopStatus {
+    profile: String,
+    mode: String,
+    driver: String,
+    profile_type: String,
+    phase: String,
+    api_endpoint: String,
+    kubeconfig_path: String,
+    profile_dir: String,
+    message: String,
+}
+
+#[derive(Serialize)]
+struct DesktopAddon {
+    name: String,
+    support: String,
+    enabled: bool,
+    message: String,
+}
+
+impl From<ClusterStatus> for DesktopStatus {
+    fn from(value: ClusterStatus) -> Self {
+        Self {
+            profile: value.profile,
+            mode: value.mode.to_string(),
+            driver: value.driver.to_string(),
+            profile_type: value.profile_type.to_string(),
+            phase: value.phase.to_string(),
+            api_endpoint: value.api_endpoint,
+            kubeconfig_path: value.kubeconfig_path.display().to_string(),
+            profile_dir: value.profile_dir.display().to_string(),
+            message: value.message,
+        }
+    }
+}
+
+impl From<AddonStatus> for DesktopAddon {
+    fn from(value: AddonStatus) -> Self {
+        Self {
+            name: value.name,
+            support: value.support.to_string(),
+            enabled: value.enabled,
+            message: value.message,
+        }
+    }
+}
+
+fn manager() -> Result<ClusterManager, String> {
+    ClusterManager::default_paths().map_err(|err| err.to_string())
+}
+
+fn parse_driver(driver: &str) -> Result<Option<RuntimeDriver>, String> {
+    if driver == "auto" || driver.is_empty() {
+        Ok(None)
+    } else {
+        RuntimeDriver::parse(driver).map(Some).map_err(|err| err.to_string())
+    }
+}
+
+#[tauri::command]
+fn create_cluster(
+    profile: String,
+    mode: String,
+    driver: String,
+    profile_type: String,
+) -> Result<DesktopStatus, String> {
+    let mode = ClusterMode::parse(&mode).map_err(|err| err.to_string())?;
+    let mut profile_type = ProfileType::parse(&profile_type).map_err(|err| err.to_string())?;
+    if mode == ClusterMode::SingleNode {
+        profile_type = ProfileType::Production;
+    }
+    manager()?
+        .create(CreateOptions {
+            profile,
+            mode,
+            driver: parse_driver(&driver)?,
+            profile_type,
+            nodes: 1,
+            node_image: None,
+            repo_root: None,
+            wait: true,
+            force: false,
+        })
+        .map(DesktopStatus::from)
+        .map_err(|err| err.to_string())
+}
+
+#[tauri::command]
+fn cluster_status(profile: String) -> Result<DesktopStatus, String> {
+    manager()?
+        .status(&profile)
+        .map(DesktopStatus::from)
+        .map_err(|err| err.to_string())
+}
+
+#[tauri::command]
+fn cluster_start(profile: String) -> Result<DesktopStatus, String> {
+    manager()?
+        .start(&profile)
+        .map(DesktopStatus::from)
+        .map_err(|err| err.to_string())
+}
+
+#[tauri::command]
+fn cluster_stop(profile: String) -> Result<DesktopStatus, String> {
+    manager()?
+        .stop(&profile)
+        .map(DesktopStatus::from)
+        .map_err(|err| err.to_string())
+}
+
+#[tauri::command]
+fn cluster_reset(profile: String) -> Result<DesktopStatus, String> {
+    manager()?
+        .reset(&profile)
+        .map(DesktopStatus::from)
+        .map_err(|err| err.to_string())
+}
+
+#[tauri::command]
+fn cluster_delete(profile: String) -> Result<String, String> {
+    manager()?.delete(&profile).map_err(|err| err.to_string())?;
+    Ok(format!("deleted profile '{profile}'"))
+}
+
+#[tauri::command]
+fn kubeconfig_path(profile: String) -> Result<String, String> {
+    manager()?
+        .kubeconfig_path(&profile)
+        .map(|path: PathBuf| path.display().to_string())
+        .map_err(|err| err.to_string())
+}
+
+#[tauri::command]
+fn cluster_logs(profile: String) -> Result<String, String> {
+    manager()?.logs(&profile).map_err(|err| err.to_string())
+}
+
+#[tauri::command]
+fn addons_list(profile: String) -> Result<Vec<DesktopAddon>, String> {
+    manager()?
+        .addons(&profile)
+        .map(|addons| addons.into_iter().map(DesktopAddon::from).collect())
+        .map_err(|err| err.to_string())
+}
+
+#[tauri::command]
+fn addon_enable(profile: String, addon: String) -> Result<String, String> {
+    manager()?
+        .enable_addon(&profile, &addon)
+        .map_err(|err| err.to_string())
+}
+
+#[tauri::command]
+fn addon_disable(profile: String, addon: String) -> Result<String, String> {
+    manager()?
+        .disable_addon(&profile, &addon)
+        .map_err(|err| err.to_string())
+}
+
+#[tauri::command]
+fn console_url(profile: String) -> Result<String, String> {
+    manager()?.console_url(&profile).map_err(|err| err.to_string())
+}
+
+#[tauri::command]
+fn smoke_test(profile: String) -> Result<String, String> {
+    manager()?.smoke_test(&profile).map_err(|err| err.to_string())
+}
+
+fn main() {
+    tauri::Builder::default()
+        .invoke_handler(tauri::generate_handler![
+            create_cluster,
+            cluster_status,
+            cluster_start,
+            cluster_stop,
+            cluster_reset,
+            cluster_delete,
+            kubeconfig_path,
+            cluster_logs,
+            addons_list,
+            addon_enable,
+            addon_disable,
+            console_url,
+            smoke_test
+        ])
+        .run(tauri::generate_context!())
+        .expect("error while running Rūsternetes Desktop");
+}
