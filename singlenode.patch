+
+    fn run_node_container(
+        &self,
+        runtime: &Runtime,
+        cfg: &ProfileConfig,
+        paths: &ProfilePaths,
+        log: &Path,
+    ) -> Result<()> {
+        let container = node_container_name(&cfg.profile, 0);
+        let runtime_socket_mount = match runtime.driver {
+            RuntimeDriver::Docker => {
+                let socket = runtime.socket.as_ref().ok_or_else(|| {
+                    ClusterError::RuntimeUnavailable(
+                        "docker socket was not detected; start Docker Desktop or set DOCKER_HOST to a unix socket".to_string(),
+                    )
+                })?;
+                if !socket.exists() {
+                    return Err(ClusterError::RuntimeUnavailable(format!(
+                        "runtime socket {} does not exist; start Docker Desktop or configure DOCKER_HOST",
+                        socket.display()
+                    )));
+                }
+                Some(format!("{}:/var/run/docker.sock", socket.display()))
+            }
+            RuntimeDriver::Podman => {
+                // Podman Desktop on macOS runs containers inside a Linux VM. The host client socket
+                // under ~/.local/share/containers/... cannot be bind-mounted into containers, but
+                // /run/podman/podman.sock is available inside the VM and exposes a Docker-compatible API.
+                Some("/run/podman/podman.sock:/var/run/docker.sock".to_string())
+            }
+        };
+
+        let mut args: Vec<String> = vec![
+            "run".to_string(),
+            "-d".to_string(),
+            "--name".to_string(),
+            container.clone(),
+            "--hostname".to_string(),
+            container.clone(),
+            "--label".to_string(),
+            format!("io.rusternetes.profile={}", cfg.profile),
+            "--label".to_string(),
+            format!("io.rusternetes.mode={}", cfg.mode),
+            "--label".to_string(),
+            "io.rusternetes.local-cluster=true".to_string(),
+            "--privileged".to_string(),
+            "--restart".to_string(),
+            if cfg.profile_type == ProfileType::Production {
+                "unless-stopped".to_string()
+            } else {
+                "no".to_string()
+            },
+            "--network".to_string(),
+            network_name(&cfg.profile),
+            "-p".to_string(),
+            format!("127.0.0.1:{}:6443", cfg.ports.api),
+            "-v".to_string(),
+            format!(
+                "{}:/var/lib/rusternetes/storage",
+                paths.storage_dir.display()
+            ),
+            "-v".to_string(),
+            format!(
+                "{}:/var/lib/rusternetes/volumes",
+                paths.volumes_dir.display()
+            ),
+            "-v".to_string(),
+            format!("{}:/var/log/rusternetes", paths.log_dir.display()),
+        ];
+        if let Some(socket_mount) = runtime_socket_mount {
+            args.push("-v".to_string());
+            args.push(socket_mount);
+        }
+        if cfg.profile_type == ProfileType::Production {
+            args.push("-v".to_string());
+            args.push(format!(
+                "{}:/var/lib/rusternetes/certs:ro",
+                paths.certs_dir.display()
+            ));
+        }
+        args.push(cfg.node_image.clone());
+        args.extend([
+            "--storage-backend".to_string(),
+            "sqlite".to_string(),
+            "--data-dir".to_string(),
+            "/var/lib/rusternetes/storage/rusternetes.db".to_string(),
+            "--bind-address".to_string(),
+            "0.0.0.0:6443".to_string(),
+            "--node-name".to_string(),
+            format!("{}-control-plane", cfg.profile),
+            "--volume-dir".to_string(),
+            "/var/lib/rusternetes/volumes".to_string(),
+            "--network".to_string(),
+            network_name(&cfg.profile),
+            "--console-dir".to_string(),
+            "/opt/rusternetes/console".to_string(),
+        ]);
+        if cfg.profile_type == ProfileType::Production {
+            args.extend([
+                "--tls".to_string(),
+                "--tls-cert-file".to_string(),
+                "/var/lib/rusternetes/certs/apiserver.crt".to_string(),
+                "--tls-key-file".to_string(),
+                "/var/lib/rusternetes/certs/apiserver.key".to_string(),
+                "--client-ca-file".to_string(),
+                "/var/lib/rusternetes/certs/ca.crt".to_string(),
+                "--skip-auth=false".to_string(),
+            ]);
+        }
+        let refs = args.iter().map(String::as_str).collect::<Vec<_>>();
+        run_runtime(runtime, &refs, log, CommandMode::RequireSuccess)?;
+        Ok(())
+    }
+
+    fn wait_for_api(&self, cfg: &ProfileConfig, timeout: Duration) -> Result<()> {
+        let deadline = SystemTime::now() + timeout;
+        let addr = SocketAddr::from(([127, 0, 0, 1], cfg.ports.api));
+        loop {
+            if TcpStream::connect_timeout(&addr, Duration::from_millis(500)).is_ok() {
+                return Ok(());
+            }
+            if SystemTime::now() >= deadline {
+                return Err(ClusterError::RuntimeUnavailable(format!(
+                    "API server did not accept TCP connections at 127.0.0.1:{} within {} seconds; inspect `rusternetes cluster logs --profile {}`",
+                    cfg.ports.api,
+                    timeout.as_secs(),
+                    cfg.profile
+                )));
+            }
+            std::thread::sleep(Duration::from_millis(500));
+        }
+    }
+
+    fn write_kubeconfig_for(&self, paths: &ProfilePaths, cfg: &ProfileConfig) -> Result<()> {
+        let server = api_endpoint(cfg);
+        let user_block = if cfg.profile_type == ProfileType::Production {
+            format!(
+                "    client-certificate: {}\n    client-key: {}\n",
+                paths.certs_dir.join("admin.crt").display(),
+                paths.certs_dir.join("admin.key").display()
+            )
+        } else {
+            "    token: rusternetes-local-dev\n".to_string()
+        };
+        let cluster_tls_block = if cfg.profile_type == ProfileType::Production {
+            format!(
+                "    certificate-authority: {}\n",
+                paths.certs_dir.join("ca.crt").display()
+            )
+        } else {
+            String::new()
+        };
+        let content = format!(
+            "apiVersion: v1\nkind: Config\nclusters:\n- name: rusternetes-{profile}\n  cluster:\n    server: {server}\n{cluster_tls_block}contexts:\n- name: rusternetes-{profile}\n  context:\n    cluster: rusternetes-{profile}\n    user: rusternetes-{profile}-admin\n    namespace: default\ncurrent-context: rusternetes-{profile}\nusers:\n- name: rusternetes-{profile}-admin\n  user:\n{user_block}",
+            profile = cfg.profile,
+            server = server,
+            cluster_tls_block = cluster_tls_block,
+            user_block = user_block,
+        );
+        fs::write(&paths.kubeconfig_file, content)?;
+        Ok(())
+    }
+
+    fn collect_container_logs(
+        &self,
+        runtime: &Runtime,
+        cfg: &ProfileConfig,
+        paths: &ProfilePaths,
+    ) -> Result<()> {
+        let mut file = OpenOptions::new()
+            .create(true)
+            .append(true)
+            .open(&paths.node_log)?;
+        for name in node_container_names(cfg) {
+            match run_runtime_capture(runtime, &["logs", &name], &paths.manager_log) {
+                Ok(output) => {
+                    writeln!(file, "===== {name} {} =====", now_unix())?;
+                    file.write_all(&output.stdout)?;
+                    file.write_all(&output.stderr)?;
+                }
+                Err(err) => {
+                    writeln!(file, "failed to collect logs for {name}: {err}")?;
+                }
+            }
+        }
+        Ok(())
+    }
+
+    fn enable_registry(&self, cfg: &ProfileConfig, paths: &ProfilePaths) -> Result<String> {
+        let runtime = Runtime::detect(Some(cfg.driver))?;
+        let container = registry_container_name(&cfg.profile);
+        run_runtime(
+            &runtime,
+            &["rm", "-f", &container],
+            &paths.manager_log,
+            CommandMode::AllowFailure,
+        )?;
+        let data_dir = paths.addon_dir.join("registry-data");
+        fs::create_dir_all(&data_dir)?;
+        let port = format!("127.0.0.1:{}:5000", cfg.ports.registry);
+        run_runtime(
+            &runtime,
+            &[
+                "run",
+                "-d",
+                "--name",
+                &container,
+                "--label",
+                &format!("io.rusternetes.profile={}", cfg.profile),
+                "--restart",
+                "unless-stopped",
+                "-p",
+                &port,
+                "-v",
+                &format!("{}:/var/lib/registry", data_dir.display()),
+                "registry:2",
+            ],
+            &paths.manager_log,
+            CommandMode::RequireSuccess,
+        )?;
+        fs::write(
+            paths.addon_dir.join("registry.env"),
+            format!(
