index 0000000..a1c8d88
--- /dev/null
+++ b/crates/rusternetes-cli/src/main.rs
@@ -0,0 +1,351 @@
+use rusternetes_cluster_manager::{
+    AddonStatus, ClusterManager, ClusterMode, ClusterStatus, CreateOptions, ProfileType,
+    RuntimeDriver,
+};
+use std::env;
+use std::process;
+
+fn main() {
+    if let Err(err) = run() {
+        eprintln!("error: {err}");
+        process::exit(1);
+    }
+}
+
+fn run() -> rusternetes_cluster_manager::Result<()> {
+    let mut args = env::args().skip(1).collect::<Vec<_>>();
+    if args.is_empty() || args[0] == "--help" || args[0] == "-h" {
+        print_help();
+        return Ok(());
+    }
+    if args[0] == "--version" || args[0] == "-V" {
+        println!("rusternetes-cli {}", env!("CARGO_PKG_VERSION"));
+        return Ok(());
+    }
+    let command = args.remove(0);
+    match command.as_str() {
+        "cluster" => cluster(args),
+        other => {
+            eprintln!("unknown command '{other}'\n");
+            print_help();
+            process::exit(2);
+        }
+    }
+}
+
+fn cluster(mut args: Vec<String>) -> rusternetes_cluster_manager::Result<()> {
+    if args.is_empty() || args[0] == "--help" || args[0] == "-h" {
+        print_cluster_help();
+        return Ok(());
+    }
+    let subcommand = args.remove(0);
+    let manager = ClusterManager::default_paths()?;
+    match subcommand.as_str() {
+        "create" => {
+            let parsed = ParsedArgs::from(args)?;
+            let mode = parsed.mode.unwrap_or(ClusterMode::Kind);
+            let mut profile_type = parsed.profile_type.unwrap_or(ProfileType::Development);
+            if mode == ClusterMode::SingleNode {
+                profile_type = ProfileType::Production;
+            }
+            let options = CreateOptions {
+                profile: parsed.profile.unwrap_or_else(|| "dev".to_string()),
+                mode,
+                driver: parsed.driver,
+                profile_type,
+                nodes: parsed.nodes.unwrap_or(1),
+                node_image: parsed.node_image,
+                repo_root: parsed.repo_root,
+                wait: !parsed.no_wait,
+                force: parsed.force,
+            };
+            let status = manager.create(options)?;
+            print_status(&status);
+        }
+        "start" => {
+            let parsed = ParsedArgs::from(args)?;
+            let status = manager.start(&profile_or_default(parsed.profile))?;
+            print_status(&status);
+        }
+        "stop" => {
+            let parsed = ParsedArgs::from(args)?;
+            let status = manager.stop(&profile_or_default(parsed.profile))?;
+            print_status(&status);
+        }
+        "status" => {
+            let parsed = ParsedArgs::from(args)?;
+            let status = manager.status(&profile_or_default(parsed.profile))?;
+            print_status(&status);
+        }
+        "kubeconfig" => {
+            let parsed = ParsedArgs::from(args)?;
+            let profile = profile_or_default(parsed.profile);
+            let path = manager.kubeconfig_path(&profile)?;
+            if parsed.path_only {
+                println!("{}", path.display());
+            } else {
+                println!("kubeconfig: {}", path.display());
+                println!("export KUBECONFIG=\"{}\"", path.display());
+            }
+        }
+        "delete" => {
+            let parsed = ParsedArgs::from(args)?;
+            let profile = profile_or_default(parsed.profile);
+            manager.delete(&profile)?;
+            println!("deleted profile '{profile}'");
+        }
+        "reset" => {
+            let parsed = ParsedArgs::from(args)?;
+            let status = manager.reset(&profile_or_default(parsed.profile))?;
+            print_status(&status);
+        }
+        "logs" => {
+            let parsed = ParsedArgs::from(args)?;
+            let logs = manager.logs(&profile_or_default(parsed.profile))?;
+            println!("{logs}");
+        }
+        "load-image" => {
+            let image = args.first().cloned().ok_or_else(|| {
+                rusternetes_cluster_manager::ClusterError::InvalidArgument(
+                    "load-image requires an image reference, for example nginx:latest".to_string(),
+                )
+            })?;
+            let remaining = args.into_iter().skip(1).collect::<Vec<_>>();
+            let parsed = ParsedArgs::from(remaining)?;
+            let message = manager.load_image(&profile_or_default(parsed.profile), &image)?;
+            println!("{message}");
+        }
+        "addons" => cluster_addons(manager, args)?,
+        "console" => {
+            let parsed = ParsedArgs::from(args)?;
+            println!(
+                "{}",
+                manager.console_url(&profile_or_default(parsed.profile))?
+            );
+        }
+        "smoke-test" | "smoke" => {
+            let parsed = ParsedArgs::from(args)?;
+            let report = manager.smoke_test(&profile_or_default(parsed.profile))?;
+            println!("{report}");
+        }
+        other => {
+            eprintln!("unknown cluster subcommand '{other}'\n");
+            print_cluster_help();
+            process::exit(2);
+        }
+    }
+    Ok(())
+}
+
+fn cluster_addons(
+    manager: ClusterManager,
+    mut args: Vec<String>,
+) -> rusternetes_cluster_manager::Result<()> {
+    if args.is_empty() || args[0] == "--help" || args[0] == "-h" {
+        print_addons_help();
+        return Ok(());
+    }
+    let subcommand = args.remove(0);
+    match subcommand.as_str() {
+        "list" => {
+            let parsed = ParsedArgs::from(args)?;
+            let addons = manager.addons(&profile_or_default(parsed.profile))?;
+            print_addons(&addons);
+        }
+        "enable" => {
+            let addon = args.first().cloned().ok_or_else(|| {
+                rusternetes_cluster_manager::ClusterError::InvalidArgument(
+                    "addons enable requires an addon name".to_string(),
+                )
+            })?;
+            let remaining = args.into_iter().skip(1).collect::<Vec<_>>();
+            let parsed = ParsedArgs::from(remaining)?;
+            let message = manager.enable_addon(&profile_or_default(parsed.profile), &addon)?;
+            println!("{message}");
+        }
+        "disable" => {
+            let addon = args.first().cloned().ok_or_else(|| {
+                rusternetes_cluster_manager::ClusterError::InvalidArgument(
+                    "addons disable requires an addon name".to_string(),
+                )
+            })?;
+            let remaining = args.into_iter().skip(1).collect::<Vec<_>>();
+            let parsed = ParsedArgs::from(remaining)?;
+            let message = manager.disable_addon(&profile_or_default(parsed.profile), &addon)?;
+            println!("{message}");
+        }
+        other => {
+            eprintln!("unknown addons subcommand '{other}'\n");
+            print_addons_help();
+            process::exit(2);
+        }
+    }
+    Ok(())
+}
+
+#[derive(Default)]
+struct ParsedArgs {
+    profile: Option<String>,
+    mode: Option<ClusterMode>,
+    driver: Option<RuntimeDriver>,
+    profile_type: Option<ProfileType>,
+    nodes: Option<usize>,
+    node_image: Option<String>,
+    repo_root: Option<std::path::PathBuf>,
+    path_only: bool,
+    no_wait: bool,
+    force: bool,
+}
+
+impl ParsedArgs {
+    fn from(args: Vec<String>) -> rusternetes_cluster_manager::Result<Self> {
+        let mut parsed = ParsedArgs::default();
+        let mut index = 0usize;
+        while index < args.len() {
+            match args[index].as_str() {
+                "--profile" | "-p" => {
+                    parsed.profile = Some(take_value(&args, index, "--profile")?);
+                    index += 2;
+                }
+                "--mode" => {
+                    parsed.mode = Some(ClusterMode::parse(&take_value(&args, index, "--mode")?)?);
+                    index += 2;
+                }
+                "--driver" => {
+                    parsed.driver = Some(RuntimeDriver::parse(&take_value(
+                        &args, index, "--driver",
+                    )?)?);
+                    index += 2;
+                }
+                "--profile-type" => {
+                    parsed.profile_type = Some(ProfileType::parse(&take_value(
+                        &args,
+                        index,
+                        "--profile-type",
+                    )?)?);
+                    index += 2;
+                }
+                "--nodes" => {
+                    let raw = take_value(&args, index, "--nodes")?;
+                    parsed.nodes = Some(raw.parse::<usize>().map_err(|err| {
+                        rusternetes_cluster_manager::ClusterError::InvalidArgument(format!(
+                            "--nodes expects a positive integer: {err}"
+                        ))
+                    })?);
+                    index += 2;
+                }
+                "--node-image" => {
+                    parsed.node_image = Some(take_value(&args, index, "--node-image")?);
+                    index += 2;
+                }
+                "--repo-root" => {
+                    parsed.repo_root = Some(take_value(&args, index, "--repo-root")?.into());
+                    index += 2;
+                }
+                "--path-only" => {
+                    parsed.path_only = true;
+                    index += 1;
+                }
+                "--no-wait" => {
+                    parsed.no_wait = true;
+                    index += 1;
+                }
+                "--force" => {
+                    parsed.force = true;
+                    index += 1;
+                }
+                "--help" | "-h" => {
+                    print_cluster_help();
+                    process::exit(0);
+                }
+                other => {
+                    return Err(rusternetes_cluster_manager::ClusterError::InvalidArgument(
+                        format!("unexpected argument '{other}'"),
+                    ));
+                }
+            }
+        }
+        Ok(parsed)
+    }
+}
+
+fn take_value(
+    args: &[String],
+    index: usize,
+    flag: &str,
+) -> rusternetes_cluster_manager::Result<String> {
+    args.get(index + 1).cloned().ok_or_else(|| {
+        rusternetes_cluster_manager::ClusterError::InvalidArgument(format!(
+            "{flag} requires a value"
+        ))
+    })
+}
+
+fn profile_or_default(profile: Option<String>) -> String {
+    profile.unwrap_or_else(|| "dev".to_string())
+}
+
+fn print_status(status: &ClusterStatus) {
+    println!("profile: {}", status.profile);
+    println!("mode: {} ({})", status.mode, status.mode.description());
+    println!("driver: {}", status.driver);
+    println!("profile_type: {}", status.profile_type);
+    println!("phase: {}", status.phase);
+    println!("api: {}", status.api_endpoint);
+    println!("kubeconfig: {}", status.kubeconfig_path.display());
+    println!("profile_dir: {}", status.profile_dir.display());
+    println!(
+        "ports: api={}, registry={}, metrics={}, service={}..{}",
+        status.ports.api,
+        status.ports.registry,
+        status.ports.metrics,
+        status.ports.service_start,
+        status.ports.service_end
+    );
+    println!("nodes:");
+    for node in &status.nodes {
+        println!(
+            "  - name={} role={} container={} runtime_status={}",
+            node.name, node.role, node.container, node.runtime_status
+        );
+    }
+    println!("addons:");
+    for addon in &status.addons {
+        println!(
+            "  - {}: support={} enabled={} message={}",
+            addon.name, addon.support, addon.enabled, addon.message
+        );
+    }
+    if !status.message.is_empty() {
+        println!("message: {}", status.message);
+    }
+    println!("{}", status.export_command());
+}
+
+fn print_addons(addons: &[AddonStatus]) {
+    println!("ADDON\tSUPPORT\tENABLED\tMESSAGE");
+    for addon in addons {
+        println!(
+            "{}\t{}\t{}\t{}",
+            addon.name, addon.support, addon.enabled, addon.message
+        );
+    }
+}
+
+fn print_help() {
+    println!(
+        "Rūsternetes local platform CLI\n\nUSAGE:\n  rusternetes cluster <subcommand> [options]\n\nRun `rusternetes cluster --help` for cluster lifecycle commands."
+    );
+}
+
+fn print_cluster_help() {
+    println!(
+        "Rūsternetes cluster orchestration\n\nUSAGE:\n  rusternetes cluster create --profile dev --driver docker --mode kind\n  rusternetes cluster create --profile dev --driver docker --mode minikube\n  rusternetes cluster create --profile prod-single --mode single-node --profile-type production\n  rusternetes cluster status --profile dev\n  rusternetes cluster kubeconfig --profile dev [--path-only]\n  rusternetes cluster start --profile dev\n  rusternetes cluster stop --profile dev\n  rusternetes cluster delete --profile dev\n  rusternetes cluster reset --profile dev\n  rusternetes cluster logs --profile dev\n  rusternetes cluster load-image nginx:latest --profile dev\n  rusternetes cluster addons list --profile dev\n  rusternetes cluster addons enable registry --profile dev\n  rusternetes cluster addons enable ingress --profile dev\n  rusternetes cluster console --profile dev\n  rusternetes cluster smoke-test --profile dev\n\nOPTIONS:\n  --profile <name>          Profile name, default dev\n  --driver <docker|podman>  Container runtime driver\n  --mode <kind|minikube|single-node>\n  --profile-type <development|production>\n  --nodes <n>               Kind-compatible mode only; single-node is implemented now\n  --node-image <image>      Override rusternetes/local-node:dev\n  --repo-root <path>        Repository root, default current directory\n  --path-only               For kubeconfig, print only the path\n  --no-wait                 Do not wait for API TCP readiness during create\n  --force                   Recreate an existing profile"
+    );
+}
+
+fn print_addons_help() {
+    println!(
+        "Rūsternetes add-ons\n\nUSAGE:\n  rusternetes cluster addons list --profile dev\n  rusternetes cluster addons enable registry --profile dev\n  rusternetes cluster addons disable registry --profile dev\n\nInitial add-ons:\n  registry   supported: local registry:2 container\n  dashboard  partial: existing embedded web console path\n  ingress    unsupported in this release; fails clearly\n  metrics    planned; fails clearly"
+    );
+}
