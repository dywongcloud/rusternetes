+#[derive(Clone, Copy)]
+enum CommandMode {
+    RequireSuccess,
+    AllowFailure,
+}
+
+fn run_runtime(runtime: &Runtime, args: &[&str], log: &Path, mode: CommandMode) -> Result<Output> {
+    run_program(&runtime.executable, args, log, mode)
+}
+
+fn run_runtime_capture(runtime: &Runtime, args: &[&str], log: &Path) -> Result<Output> {
+    run_program(&runtime.executable, args, log, CommandMode::RequireSuccess)
+}
+
+fn run_program(program: &str, args: &[&str], log: &Path, mode: CommandMode) -> Result<Output> {
+    append_log(log, &format!("$ {} {}\n", program, args.join(" "))).ok();
+    let output = Command::new(program).args(args).output().map_err(|err| {
+        ClusterError::RuntimeUnavailable(format!("failed to execute '{program}': {err}"))
+    })?;
+    append_log_output(log, &output).ok();
+    if output.status.success() || matches!(mode, CommandMode::AllowFailure) {
+        Ok(output)
+    } else {
+        Err(ClusterError::CommandFailed {
+            command: format!("{} {}", program, args.join(" ")),
+            status: output.status.code(),
+            stdout: String::from_utf8_lossy(&output.stdout).to_string(),
+            stderr: String::from_utf8_lossy(&output.stderr).to_string(),
+        })
+    }
+}
+
+fn append_log(path: &Path, message: &str) -> Result<()> {
+    if path == Path::new("/dev/null") {
+        return Ok(());
+    }
+    if let Some(parent) = path.parent() {
+        fs::create_dir_all(parent)?;
+    }
+    let mut file = OpenOptions::new().create(true).append(true).open(path)?;
+    file.write_all(message.as_bytes())?;
+    Ok(())
+}
+
+fn append_log_output(path: &Path, output: &Output) -> Result<()> {
+    if path == Path::new("/dev/null") {
+        return Ok(());
+    }
+    let mut file = OpenOptions::new().create(true).append(true).open(path)?;
+    writeln!(file, "status: {}", output.status)?;
+    if !output.stdout.is_empty() {
+        writeln!(file, "stdout:")?;
+        file.write_all(&output.stdout)?;
+        writeln!(file)?;
+    }
+    if !output.stderr.is_empty() {
+        writeln!(file, "stderr:")?;
+        file.write_all(&output.stderr)?;
+        writeln!(file)?;
+    }
+    Ok(())
+}
+
+fn inspect_container_status(runtime: &Runtime, container: &str, log: &Path) -> Result<String> {
+    let output = run_runtime(
