# Rusternetes Development Environment Configuration
# Copy this file to .env and customize as needed

# Logging configuration
RUST_LOG=info
# Options: trace, debug, info, warn, error
# Example for component-specific logging:
# RUST_LOG=rusternetes_api_server=debug,rusternetes_scheduler=info

# etcd configuration
ETCD_SERVERS=http://etcd:2379
# For multiple etcd servers (HA setup):
# ETCD_SERVERS=http://etcd1:2379,http://etcd2:2379,http://etcd3:2379

# API Server configuration
API_SERVER_BIND_ADDRESS=0.0.0.0:6443
API_SERVER_SECURE_PORT=6443

# Container Runtime
# Podman or Docker socket location
DOCKER_HOST=unix:///var/run/docker.sock

# Node configuration
NODE_NAME=node-1
NODE_IP=127.0.0.1

# Image configuration (for building custom images)
IMAGE_PREFIX=rusternetes
IMAGE_TAG=latest
REGISTRY_URL=localhost:5000

# Development options
# Set to 1 to enable development mode features
DEV_MODE=1
DEBUG_LOGGING=0

# Resource limits (optional)
# Memory limits for containers (in MB)
API_SERVER_MEMORY=512
SCHEDULER_MEMORY=256
CONTROLLER_MEMORY=256
KUBELET_MEMORY=512
KUBE_PROXY_MEMORY=128

# Feature flags (optional)
ENABLE_AUTHENTICATION=true
ENABLE_RBAC=true
ENABLE_METRICS=true
ENABLE_TRACING=false
